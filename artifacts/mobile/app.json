{
  "expo": {
    "name": "Card Scanner Pro Mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elitemarcom.cardscannerpro"
    },
    "android": {
      "package": "com.elitemarcom.cardscannerpro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FF6B00"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter_400Regular.ttf",
            "./assets/fonts/Inter_500Medium.ttf",
            "./assets/fonts/Inter_600SemiBold.ttf",
            "./assets/fonts/Inter_700Bold.ttf",
            "./assets/fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Card Scanner Pro to use the camera to scan business cards, badges, and QR codes."
        }
      ],
      "expo-secure-store",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Card Scanner Pro to save captured leads to your phone contacts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Card Scanner Pro to use Face ID to unlock the app."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Card Scanner Pro to attach the event location to captured leads."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Card Scanner Pro to choose a profile photo from your library.",
          "cameraPermission": "Allow Card Scanner Pro to take a profile photo."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF6B00"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
